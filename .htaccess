<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Handle WordPress blog (assuming it lives in public/blog)
    # If the request starts with /blog, rewrite it to the public/blog folder
    RewriteCond %{REQUEST_URI} ^/blog
    RewriteRule ^blog(/.*)?$ public/blog/$1 [L,QSA]

    # 2. Prevent loops and redirect /public requests to root
    RewriteCond %{REQUEST_URI} ^/public/
    RewriteRule ^public/(.*)$ /$1 [L,R=301]

    # 3. Handle Laravel Routing
    # Send everything that is NOT a physical file/directory OR is the root / to public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f [OR]
    RewriteCond %{REQUEST_URI} ^/$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/blog
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>
