<IfModule mod_rewrite.c>
    RewriteEngine On

    # ✅ Force root (/) to Laravel
    RewriteRule ^$ public/index.php [L]

    # ✅ WordPress blog
    RewriteRule ^blog(/.*)?$ public/blog/$1 [L]

    # ✅ Laravel for all other routes
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L]
</IfModule>